services:
  postgres:
    image: {{ lock.deployment.images.postgres }}
    container_name: shared-postgress
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${POSTGRES_DB}
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    volumes:
      - {{ lock.deployment.state.postgres }}:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $$POSTGRES_USER -d $$POSTGRES_DB"]
      interval: 10s
      timeout: 5s
      retries: 10

{% for svc in lock.deployment.services %}
  vllm-{{ svc.service_name }}:
    image: {{ lock.deployment.images.vllm }}
    container_name: vllm-{{ svc.service_name }}
    restart: unless-stopped
    environment:
      NVIDIA_DRIVER_CAPABILITIES: compute,utility
      HF_TOKEN: ${HF_TOKEN}
      VLLM_API_KEY: ${VLLM_BACKEND_API_KEY}
{% if lock.deployment.vllm.enable_responses_api_store %}
      VLLM_ENABLE_RESPONSES_API_STORE: "1"
{% endif %}
      VLLM_LOGGING_LEVEL: "{{ lock.deployment.vllm.logging_level }}"
    command:
      - "{{ svc.hf_model_id }}"
      - --host
      - 0.0.0.0
      - --port
      - "8000"
      - --api-key
      - ${VLLM_BACKEND_API_KEY}
      - --served-model-name
      - "{{ svc.served_model_name }}"
      - --tensor-parallel-size
      - "{{ svc.tensor_parallel_size }}"
      - --data-parallel-size
      - "{{ svc.data_parallel_size }}"
      - --max-model-len
      - "{{ svc.max_model_len }}"
      - --gpu-memory-utilization
      - "{{ svc.gpu_memory_utilization }}"
      - --max-num-batched-tokens
      - "{{ svc.max_num_batched_tokens }}"
      - --max-num-seqs
      - "{{ svc.max_num_seqs }}"
{% if svc.enable_prefix_caching %}
      - --enable-prefix-caching
{% endif %}
{% if svc.enable_auto_tool_choice %}
      - --enable-auto-tool-choice
      - --tool-call-parser
      - "{{ svc.tool_call_parser }}"
{% endif %}
    volumes:
      - {{ lock.deployment.state.hf_cache }}:/root/.cache/huggingface
    ports:
      - "127.0.0.1:{{ 18000 + loop.index0 }}:8000"
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:8000/health >/dev/null 2>&1 || exit 1"]
      interval: 20s
      timeout: 10s
      retries: 30
      start_period: 120s
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              device_ids: [{% for idx in svc.gpu_indices %}"{{ idx }}"{% if not loop.last %}, {% endif %}{% endfor %}]
              capabilities: [gpu]

{% endfor %}
  litellm:
    image: {{ lock.deployment.images.litellm }}
    container_name: litellm
    restart: unless-stopped
    depends_on:
{% for svc in lock.deployment.services %}
      vllm-{{ svc.service_name }}:
        condition: service_healthy
{% endfor %}
    environment:
      LITELLM_MASTER_KEY: ${LITELLM_MASTER_KEY}
      VLLM_BACKEND_API_KEY: ${VLLM_BACKEND_API_KEY}
      DATABASE_URL: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
    command:
      - --config
      - /app/config.yaml
      - --port
      - "4000"
      - --num_workers
      - "1"
    volumes:
      - {{ lock.deployment.state.runtime }}/litellm_config.yaml:/app/config.yaml:ro
    ports:
      - "{{ lock.deployment.ports.litellm }}:4000"

  open-webui:
    image: {{ lock.deployment.images.open_webui }}
    container_name: open-webui
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
      litellm:
        condition: service_started
    environment:
      WEBUI_AUTH: "True"
      ENABLE_PERSISTENT_CONFIG: "False"
      DATABASE_URL: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
      OPENAI_API_BASE_URL: http://litellm:4000/v1
      OPENAI_API_KEY: ${LITELLM_MASTER_KEY}
      WEBUI_SECRET_KEY: ${WEBUI_SECRET_KEY}
    volumes:
      - {{ lock.deployment.state.open_webui }}:/app/backend/data
    ports:
      - "{{ lock.deployment.ports.open_webui }}:8080"
